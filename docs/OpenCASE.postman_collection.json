    {
      "name": "Management",
      "description": "Extended management API (non-CASE standard).\n\nAll endpoints require authentication. Tenant ID in the URL must match the JWT `tenantId` claim.",
      "item": [
        {
          "name": "Tenants",
          "description": "Tenant CRUD — requires `case.admin` scope.",
          "item": [
            {
              "name": "List Tenants",
              "request": {
