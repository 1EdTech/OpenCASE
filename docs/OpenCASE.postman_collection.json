          }
        },
        {
          "name": "Get CFLicense",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ims/case/v1p0/CFLicenses/{{license_id}}",
              "host": ["{{base_url}}"],
              "path": ["ims", "case", "v1p0", "CFLicenses", "{{license_id}}"]
