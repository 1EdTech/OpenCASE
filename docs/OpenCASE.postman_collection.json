    {
      "name": "Management",
      "description": "Extended management API (non-CASE standard).\n\nAll endpoints require authentication. Tenant ID in the URL must match the JWT `tenantId` claim.",
      "item": [
        {
          "name": "Tenants",
          "description": "Tenant CRUD — requires `case.admin` scope.",
          "item": [
            {
              "name": "List Tenants",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/management/tenants",
                  "host": ["{{base_url}}"],
                  "path": ["management", "tenants"]
                },
                "description": "Requires `case.admin` scope."
              }
            },
            {
              "name": "Create Tenant",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"tenantId\": \"new-tenant\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/management/tenants",
                  "host": ["{{base_url}}"],
                  "path": ["management", "tenants"]
                },
                "description": "Requires `case.admin` scope.\n\nCreates tenant data directories and provisions a Keycloak client + admin user.\n\nReturns the admin credentials (temporary password)."
              }
            }
          ]
        },
        {
          "name": "CFPackages (v1p0)",
          "item": [
            {
              "name": "List CFPackages",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/management/tenants/{{tenant_id}}/CFPackages?caseVersion=1.0",
                  "host": ["{{base_url}}"],
                  "path": ["management", "tenants", "{{tenant_id}}", "CFPackages"],
                  "query": [
                    { "key": "caseVersion", "value": "1.0" },
                    { "key": "includeArchived", "value": "false", "disabled": true }
                  ]
                }
              }
            },
            {
              "name": "Create/Publish CFPackage",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"CFDocument\": {\n    \"identifier\": \"00000000-0000-0000-0000-000000000001\",\n    \"uri\": \"urn:example:doc\",\n    \"title\": \"Example Framework\",\n    \"creator\": \"Author\",\n    \"lastChangeDateTime\": \"2026-01-01T00:00:00Z\"\n  },\n  \"CFItems\": [],\n  \"CFAssociations\": []\n}"
                },
                "url": {
                  "raw": "{{base_url}}/management/tenants/{{tenant_id}}/ims/case/v1p0/CFPackages",
                  "host": ["{{base_url}}"],
                  "path": ["management", "tenants", "{{tenant_id}}", "ims", "case", "v1p0", "CFPackages"]
                }
              }
            },
            {
              "name": "Import CFPackage from Endpoint",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"endpointUrl\": \"https://example.com/ims/case/v1p0/CFPackages/some-uuid\",\n  \"accessToken\": \"\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/management/tenants/{{tenant_id}}/ims/case/v1p0/CFPackages/import",
                  "host": ["{{base_url}}"],
                  "path": ["management", "tenants", "{{tenant_id}}", "ims", "case", "v1p0", "CFPackages", "import"]
                }
              }
            },
            {
              "name": "Delete CFPackage (archive)",
              "request": {
                "method": "DELETE",
                "url": {
                  "raw": "{{base_url}}/management/tenants/{{tenant_id}}/ims/case/v1p0/CFPackages/{{doc_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["management", "tenants", "{{tenant_id}}", "ims", "case", "v1p0", "CFPackages", "{{doc_id}}"],
                  "query": [
                    { "key": "hardDelete", "value": "false", "disabled": true, "description": "Set to true for permanent deletion" }
                  ]
                }
              }
            },
            {
              "name": "Restore CFPackage",
              "request": {
                "method": "POST",
                "url": {
                  "raw": "{{base_url}}/management/tenants/{{tenant_id}}/ims/case/v1p0/CFPackages/{{doc_id}}/restore",
                  "host": ["{{base_url}}"],
                  "path": ["management", "tenants", "{{tenant_id}}", "ims", "case", "v1p0", "CFPackages", "{{doc_id}}", "restore"]
                }
              }
            }
          ]
        },
        {
          "name": "CFPackages (v1p1)",
          "item": [
            {
              "name": "List CFPackages",
              "request": {
                "method": "GET",
                "url": {
