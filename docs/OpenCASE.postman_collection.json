              "host": ["{{base_url}}"],
              "path": ["ims", "case", "v1p0", "CFAssociationGroupings", "{{association_grouping_id}}"]
            }
          }
        },
        {
          "name": "Get CFItemType",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ims/case/v1p0/CFItemTypes/{{item_type_id}}",
              "host": ["{{base_url}}"],
              "path": ["ims", "case", "v1p0", "CFItemTypes", "{{item_type_id}}"]
