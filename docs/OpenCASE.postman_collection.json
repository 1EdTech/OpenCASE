                  "query": [
                    { "key": "caseVersion", "value": "1.1" },
                    { "key": "includeArchived", "value": "false", "disabled": true }
                  ]
                }
              }
            },
            {
              "name": "Create/Publish CFPackage",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
