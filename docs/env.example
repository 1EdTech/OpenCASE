# =============================================================================
# OpenCASE Monorepo - Environment Configuration
# =============================================================================
# Copy this file to .env in the project root and modify as needed.
# Docker Compose will automatically load .env from the project root.
#
# URLs are constructed automatically in docker-compose.yml from the base
# variables below. You only need to set them once here.

# =============================================================================
# TLS Mode — Choose ONE of the two blocks below
# =============================================================================
# HTTPS requires a domain name; HTTP works with localhost or an IP address.

# --- HTTPS (production) — TLS on :443, Let's Encrypt, HTTP redirect on :80 ---
TRAEFIK_CONFIG=traefik/traefik-https.yml
TRAEFIK_PORTS_WEB=443:443
TRAEFIK_PORTS_ALT=80:80
KEYCLOAK_SSL_REQUIRED=external
OPENCASE_SCHEME=https
OPENCASE_PORT_SUFFIX=

# --- HTTP (local development) — plain HTTP on :3000, dashboard on :8080 ---
# TRAEFIK_CONFIG=traefik/traefik-http.yml
# TRAEFIK_PORTS_WEB=3000:3000
# TRAEFIK_PORTS_ALT=8080:8080
# KEYCLOAK_SSL_REQUIRED=none
# OPENCASE_SCHEME=http
# OPENCASE_PORT_SUFFIX=:3000

# =============================================================================
# Core Settings
# =============================================================================
# These are referenced throughout docker-compose.yml to construct URLs,
# configure services, and set credentials. Change them here — once.

# Public hostname or domain name for your server
# HTTPS mode: must be a domain name (Let's Encrypt can't issue certs for IPs)
# HTTP mode: can be localhost, an IP, or a domain name
OPENCASE_HOSTNAME=localhost

# Shared admin password (Keycloak console + system admin + OpenCASE API client)
ADMIN_PASSWORD=admin

# Keycloak realm name
KEYCLOAK_REALM=opencase

# =============================================================================
# Let's Encrypt (HTTPS mode only)
# =============================================================================

# Email for certificate registration and expiry warnings
# Required for HTTPS mode. Leave empty for HTTP mode.
ACME_EMAIL=

# =============================================================================
# System Admin Bootstrap
# =============================================================================

# A system admin user is created on first startup with these credentials
KEYCLOAK_SYSTEM_ADMIN_EMAIL=system-admin@local
# Password uses ADMIN_PASSWORD above

# =============================================================================
# SMTP Configuration (for Keycloak email delivery)
# =============================================================================

# Dev: points to Mailpit container (view emails at http://localhost:8025)
# Production: set to your real SMTP server
SMTP_HOST=mailpit
SMTP_PORT=1025
# SMTP_FROM is auto-derived as noreply@OPENCASE_HOSTNAME

# =============================================================================
# Single-Tenant Mode (optional)
# =============================================================================

# Skip the tenant lookup screen and sign in directly with this tenant.
# Leave empty (or remove) for multi-tenant / multi-org SSO (Organization ID or email login).
# Do NOT set this for 1EdTech multi-org Auth0 deployments — use org-id login instead.
DEFAULT_TENANT_ID=

# =============================================================================
# CASE Global (CGE) integration
# =============================================================================

# OAuth token endpoint for org API keys (client_credentials)
# CGE_TOKEN_URL=https://cge.example.com/realms/caseglobal/protocol/openid-connect/token

# Coalition API base URL
# CGE_API_BASE_URL=https://cge.example.com

# Required to store per-tenant CGE client secrets (AES-256-GCM at rest)
# CGE_CREDENTIALS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Access-token claim carrying Auth0 org id (must equal OpenCASE tenantId)
SSO_ORG_CLAIM=org_id

# =============================================================================
# Advanced (rarely need to change)
# =============================================================================

OIDC_CLIENT_ID_PREFIX=tenant-
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_SYSTEM_ADMIN=true
CASE_DATA_DIR=/app/data
